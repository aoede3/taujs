{
  "name": "@taujs/react",
  "version": "0.5.0",
  "description": "Framework-agnostic React SSR primitives - transport layer for server-side rendering and hydration",
  "author": "Aoede <taujs@aoede.uk.net> (https://www.aoede.uk.net)",
  "license": "MIT",
  "homepage": "https://taujs.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aoede3/taujs.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/aoede3/taujs/issues"
  },
  "keywords": [
    "fastify",
    "typescript",
    "esm",
    "vite",
    "streaming",
    "react",
    "ssr"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer.d.ts",
      "import": "./dist/renderer.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@babel/preset-typescript": "^7.24.7",
    "@taujs/server": "workspace:*",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^24.0.7",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@vitejs/plugin-react": "^4.6.0 || ^5.0.0",
    "@types/node": ">=20",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vite": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-react": {
      "optional": true
    },
    "@types/node": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:ui": "vitest --ui --coverage.enabled=true",
    "coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "check-exports": "attw --pack . --profile esm-only"
  },
  "sideEffects": false
}
