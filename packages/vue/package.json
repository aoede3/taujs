{
  "name": "@taujs/vue",
  "version": "0.2.0",
  "description": "Framework-agnostic Vue SSR primitives - transport layer for server-side rendering and hydration",
  "author": "Aoede <taujs@aoede.uk.net> (https://www.aoede.uk.net)",
  "license": "MIT",
  "homepage": "https://taujs.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aoede3/taujs.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/aoede3/taujs/issues"
  },
  "keywords": [
    "fastify",
    "typescript",
    "esm",
    "vite",
    "streaming",
    "vue",
    "ssr",
    "vue3"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@babel/preset-typescript": "^7.24.7",
    "@taujs/server": "workspace:*",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "@vue/server-renderer": "^3.5.13",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.3",
    "tsup": "^8.2.4",
    "typescript": "^5.7.2",
    "vite": "^7.1.9",
    "vitest": "^3.2.4",
    "vue": "^3.5.25"
  },
  "peerDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/server-renderer": "^3.5.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.9",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-vue": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:ui": "vitest --ui --coverage.enabled=true",
    "coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "check-exports": "attw --pack . --profile esm-only"
  }
}
