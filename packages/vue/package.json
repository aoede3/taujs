{
  "name": "@taujs/vue",
  "version": "0.1.0",
  "private": true,
  "description": "Framework-agnostic Vue SSR primitives - transport layer for server-side rendering and hydration",
  "author": "Aoede <taujs@aoede.uk.net> (https://www.aoede.uk.net)",
  "license": "MIT",
  "homepage": "https://github.com/aoede3/taujs-vue",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aoede3/taujs-vue.git"
  },
  "bugs": {
    "url": "https://github.com/aoede3/taujs-vue/issues"
  },
  "keywords": [
    "vue",
    "ssr",
    "server-side-rendering",
    "hydration",
    "streaming",
    "typescript",
    "esm",
    "vite",
    "express",
    "fastify",
    "koa",
    "vue3"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.15.4",
    "@babel/preset-typescript": "^7.24.7",
    "@changesets/cli": "^2.27.7",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "@vue/server-renderer": "^3.5.13",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.3",
    "tsup": "^8.2.4",
    "typescript": "^5.7.2",
    "vite": "^7.1.9",
    "vitest": "^3.2.4",
    "vue": "^3.5.25"
  },
  "peerDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/server-renderer": "^3.4.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.9"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-vue": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "build-local": "tsup && ./move.sh",
    "ci": "npm run build && npm run check-format && npm run lint",
    "lint": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest --ui --coverage.enabled=true",
    "coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "check-exports": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
    "prepublishOnly": "npm run ci",
    "local-release": "npm run ci && changeset version && changeset publish"
  }
}
