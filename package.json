{
  "name": "taujs",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r lint",
    "check-format": "prettier --check .",
    "format": "prettier --write .",
    "ci": "pnpm run build && pnpm run typecheck && pnpm run check-format && pnpm run test",
    "version": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
