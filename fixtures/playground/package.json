    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.5.4",
    "vite": "^7.3.6",
    "@taujs/mcp": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
